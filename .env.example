DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

DATABASE_URL=postgres://fleetpredict:fleetpredict@postgres:5432/fleetpredict
CHANNEL_LAYERS_USE_REDIS=1
REDIS_URL=redis://redis:6379/0
TELEMETRY_WS_TOKEN=change-me

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=FleetPredict <noreply@fleetpredict.local>
LOG_LEVEL=INFO
SECURE_HSTS_SECONDS=0

